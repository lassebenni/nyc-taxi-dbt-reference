nyc_taxi:
  target: databricks
  outputs:
    databricks:
      type: databricks
      catalog: hyf
      schema: "{{ env_var('DBT_SCHEMA') }}"
      host: "{{ env_var('DBRICKS_HOST') }}"
      http_path: "{{ env_var('DBRICKS_HTTP_PATH') }}"
      token: "{{ env_var('DBRICKS_TOKEN') }}"
      threads: 4
